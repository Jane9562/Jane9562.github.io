---
import Layout from "../../layouts/Layout.astro";
import FriendLinks from "@/components/friends/FriendLinks.astro";
import ProjectsNote from "@/content/projects-note.md";
import themeConfig from "@/theme.config";

const projectsConfig = themeConfig.friends;
const projectLinks = projectsConfig?.links ?? [];
const pageTitle = projectsConfig?.title ?? "项目";
const pageDescription =
  projectsConfig?.description ?? "这里收录我正在做或想继续完善的项目。";
---

<Layout pageTitle={pageTitle}>
  <div class="wrap friend-page">
    <div class="friend-header">
      <h2>{pageTitle}</h2>
      <p>{pageDescription}</p>
    </div>
    <section class="friend-section friend-rules">
      <h3>项目说明</h3>
      <div class="friend-rules-content">
        <ProjectsNote />
      </div>
    </section>
    <section class="friend-section friend-links-section">
      <h3>项目卡片</h3>
      <FriendLinks links={projectLinks} />
    </section>
  </div>
</Layout>

<style>
  .friend-page {
    padding: 1.5rem 1.75rem 2.5rem;
  }

  .friend-header {
    margin-bottom: 1.5rem;
  }

  .friend-section {
    margin-top: 2rem;
  }

  .friend-header h2 {
    margin: 0 0 0.35rem;
    font-size: 1.75rem;
    color: var(--grey-7);
  }

  .friend-header p {
    margin: 0;
    color: var(--grey-6);
  }

  .friend-rules h3,
  .friend-links-section h3 {
    margin: 0 0 0.75rem;
    color: var(--grey-7);
  }

  .friend-rules-content {
    padding: 1rem 1.1rem;
    border-radius: 0.75rem;
    background: linear-gradient(135deg, var(--grey-0), var(--grey-1));
    border: 1px solid var(--grey-2);
    color: var(--grey-7);
    box-shadow: 0 0.6rem 1.2rem var(--box-bg-shadow);
  }

  .friend-rules-content :global(p) {
    margin: 0 0 0.75rem;
    color: var(--grey-6);
    line-height: 1.7;
  }

  .friend-rules-content :global(ul) {
    margin: 0;
    padding-left: 1.2rem;
    color: var(--grey-6);
  }

  .friend-rules-content :global(li) {
    margin: 0.4rem 0;
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .friend-page {
      padding: 1.25rem 1rem 2rem;
    }
  }
</style>
